# RAILWAY STAGING ENVIRONMENT VARIABLES
# Copy to Railway Dashboard → Services → Environment Variables

# ===== BACKEND (FastAPI) =====
DATABASE_URL=postgresql+asyncpg://user:password@db.railway.app/erp_fabs_ci_staging
JWT_SECRET=your-secret-key-min-32-chars-replace-in-production
ALLOWED_ORIGINS=https://frontend-staging.railway.app,https://yourdomain.com
ENVIRONMENT=staging
LOG_LEVEL=info
API_PORT=8000

# ===== FRONTEND (React) =====
REACT_APP_API_BASE_URL=https://backend-staging.railway.app/api
REACT_APP_ENVIRONMENT=staging

# ===== OPTIONAL: MONITORING =====
SENTRY_DSN=https://your-sentry-url
DATADOG_API_KEY=your-datadog-key

# ===== DATABASE BACKUP =====
# Railway auto-backs up daily. Enable point-in-time recovery if needed.
POSTGRES_BACKUP_RETENTION=30  # days
